# Server
PORT=3001
NODE_ENV=development

# Database (PostgreSQL via Railway or Supabase)
DATABASE_URL="postgresql://user:password@localhost:5432/jib_community"

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# CORS
ALLOWED_ORIGINS=http://localhost:3000,https://community.jesusisbetter.org

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
